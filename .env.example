# =====================================================
# CRM FSD — Variables d'environnement (template)
# =====================================================
# Copier ce fichier en .env (qui est ignoré par Git)
# JAMAIS committer le .env réel.
# =====================================================

# --- Supabase (projet ajukuwrznhfsfdeejdkl) ---
SUPABASE_URL=https://ajukuwrznhfsfdeejdkl.supabase.co
SUPABASE_PROJECT_REF=ajukuwrznhfsfdeejdkl

# Clé anon — publique, peut être dans le front
SUPABASE_ANON_KEY=eyJhbGc...REMPLACER...

# Clé service_role — SECRETE, jamais dans le front, jamais dans Git
SUPABASE_SERVICE_KEY=eyJhbGc...REMPLACER...

# --- DB direct connection (pour outils CLI : psql, supabase, dump) ---
# Récupérer dans Dashboard > Project Settings > Database > Connection string
SUPABASE_DB_HOST=db.ajukuwrznhfsfdeejdkl.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=REMPLACER

# Connection string complète (chiffrement requis en prod)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ajukuwrznhfsfdeejdkl.supabase.co:5432/postgres
